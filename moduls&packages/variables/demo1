package variables

import "fmt"

func Demo1() {
	var message string = "hello world"
	fmt.Println(message)

	var eq int = 10
	fmt.Println(eq)

	var eq2 float32 = 0.1
	fmt.Println(eq2)

	eq3 := 25.2
	fmt.Println(eq3)
	fmt.Println("data type: %T", eq3)

	var status bool = false

	var string1 string = "angora"
	var string2 string = "dikmen"

	status = string1 == string2
	fmt.Println(status)
	fmt.Println(!status)
}
